# ============================================================================
#  TCA Catch Reports Export — local secrets  (NOT tracked by git)
# ============================================================================
#  This file holds your private API key. It is excluded from git so your key
#  is never pushed. config.cmd fills it in for you, or you can paste it below.
# ============================================================================

# The API key we emailed you. It looks like  tca_live_xxxxxxxx
MT_EXPORT_API_KEY=tca_live_PASTE_YOUR_KEY_HERE
