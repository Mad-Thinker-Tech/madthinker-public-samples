# ============================================================================
#  TCA Catch Reports Export — shared configuration
# ============================================================================
#  These are non-secret settings, safe to keep in the repository.
#  Your private API key does NOT go here — it lives in config.env.local,
#  which config.cmd creates for you and which git never tracks.
#
#  Lines starting with # are comments. Do not put spaces around the = sign.
# ============================================================================

# The production export endpoint. Leave this as-is unless we tell you otherwise.
MT_EXPORT_API_URL=https://koxeklkffxewmkasocvk.supabase.co/functions/v1/tca-catch-reports-export

# Folder where photos are downloaded. Leave as-is for a "photos" folder next to
# this file, or set it to blank (MT_EXPORT_PHOTO_DIR=) to skip photos entirely.
MT_EXPORT_PHOTO_DIR=photos

# Local database file that holds the mirrored catch reports. Leave as-is.
MT_EXPORT_DB_PATH=catch_reports.db

# Rows fetched per request, 1–5000. Leave as-is unless advised.
MT_EXPORT_LIMIT=1000
